# AgentMail Environment Config

# Bitcoin HD wallet extended public key (xpub/zpub)
# Without this, addresses are mocked (dev mode)
# BTC_XPUB=xpub6...

# Public URL of this service (needed for mempool.space webhooks)
# Must be HTTPS reachable from the internet
# PUBLIC_URL=https://agentmail.cdnsoft.net

# Admin API key for protected endpoints
ADMIN_KEY=change-me-in-production

# Service config
PORT=3210
