# AgentMail Environment Config

# Bitcoin HD wallet extended public key (xpub/zpub)
# Without this, addresses are mocked (dev mode)
# BTC_XPUB=xpub6...

# Public URL of this service (needed for mempool.space webhooks)
# Must be HTTPS reachable from the internet
# PUBLIC_URL=https://agentmail.cdnsoft.net

# Admin API key for protected endpoints
ADMIN_KEY=change-me-in-production

# Migadu email backend
# Get API key from: https://admin.migadu.com/account/api
# MIGADU_USER=admin@yourdomain.com
# MIGADU_KEY=your-migadu-api-key
# MIGADU_DOMAIN=agentmail.cdnsoft.net

# Service config
PORT=3210

# ── Inbound SMTP server (built-in) ──────────────────────────────────────
# Set SMTP_INBOUND=true to start the built-in SMTP daemon.
# DNS: Add an MX record pointing to this server's IP.
# Port 25 requires root. Use iptables redirect or run as root.
# Tip: use port 2525 with: SMTP_INBOUND_PORT=2525
#   then: sudo iptables -t nat -A PREROUTING -p tcp --dport 25 -j REDIRECT --to-port 2525
# SMTP_INBOUND=true
# SMTP_INBOUND_PORT=2525

# ── SMTP relay (outbound via central server) ────────────────────────────
# Alternative to Migadu: use Brevo, Mailgun, SendGrid, or any SMTP relay.
# Agents' emails will appear to come from their mailbox address.
# SMTP_RELAY_HOST=smtp-relay.brevo.com
# SMTP_RELAY_PORT=587
# SMTP_RELAY_USER=your@email.com
# SMTP_RELAY_PASS=your-smtp-key
