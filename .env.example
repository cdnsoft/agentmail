# AgentMail Configuration

# Bitcoin xpub for deriving per-mailbox receiving addresses
# Generate with: bitcoin-wallet or electrum xpub export
BTC_XPUB=xpub6...

# Admin key for protected endpoints
ADMIN_KEY=change-this-to-a-secure-random-string

# Server port
PORT=3210

# Database path (optional, defaults to ./data/agentmail.db)
# DB_PATH=/var/lib/agentmail/agentmail.db
